post_install() {
    post_upgrade
}

post_upgrade() {
    # Boot counting / health tracking
    systemctl enable mark-boot-in-progress.service   # WantedBy=local-fs.target
    systemctl enable mark-boot-success.service        # WantedBy=multi-user.target
    systemctl enable bless-boot.service               # WantedBy=multi-user.target
    systemctl enable check-boot-failure.timer         # WantedBy=timers.target + emergency.target

    # User setup (path unit activates the service — only enable the path)
    systemctl enable shani-user-setup.path            # WantedBy=multi-user.target

    # Bees deduplication
    systemctl enable beesd-setup.service              # WantedBy=multi-user.target

    # System-wide Flatpak (timer activates the service — only enable the timer)
    systemctl enable flatpak-update-system.timer      # WantedBy=timers.target

    # User-scope units (timer activates the service — only enable the timer)
    systemctl --global enable flatpak-update-user.timer   # WantedBy=timers.target
    systemctl --global enable shani-update.timer          # WantedBy=multi-user.target
}
