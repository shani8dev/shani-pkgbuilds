[Cursor Options]
CursorShape=2
CustomCursorColor=255,127,80
UseCustomCursorColor=true

[General]
ColorScheme=SaturnDark
Command=/usr/bin/fish
Name=Shani
Parent=FALLBACK/
TerminalColumns=110

[Interaction Options]
